# ===== Supabase =====
# From Supabase project → Settings → API keys → "Publishable / Secret API keys" tab
# (not the legacy "anon / service_role" tab — those still work but are being phased out).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ===== Google: service account (Sheets/Forms — RECOMMENDED) =====
# Create at: Google Cloud Console → IAM → Service Accounts → "Create" → grant no IAM roles
# → on the service account, "Keys" tab → "Add key" → JSON. Download.
# Save the file at project root (gitignored) and point to it here.
# Share the master Sheet and Form responses Sheet with the service account's email
# (xxxxx@your-project.iam.gserviceaccount.com) — give it Editor for write-back tracking columns,
# or Viewer if you don't need write-back yet.
GOOGLE_SERVICE_ACCOUNT_KEYFILE=./service-account.json
# Alternative for Vercel/production: paste the entire JSON file's contents base64-encoded:
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=...

# ===== Google: OAuth (Gmail send — Phase 1+) =====
# Only needed when we wire send-as-organiser email. Skip for Phase 0.
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_SHEETS_REFRESH_TOKEN=

# ===== Sheet IDs =====
MASTER_SHEET_ID=1EFbLg-1TAXwTlneeVTkP5M4x8bQ7mWAlF-Q6Q4Ii6Ng
FORM_RESPONSES_SHEET_ID=

# ===== WhatsApp router (cross-app inbound ownership) =====
# The other backend that owns the Meta webhook URL for the shared business number.
# See docs/whatsapp-router-spec.md.
ROUTER_BASE_URL=
# Shared secret this app uses when calling the router's /contacts/claim endpoint.
ROUTER_API_SECRET=
# Shared secret the router uses when forwarding inbound to this app's /api/whatsapp/inbound.
INBOUND_FORWARD_SECRET=
# Path appended to ROUTER_BASE_URL for the claim endpoint. Defaults match the live router.
ROUTER_CLAIM_PATH=/v2/webhooks/contacts/claim

# ===== WhatsApp send (Meta Cloud API direct — Phase 2H, not yet wired) =====
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WABA_ID=
META_WHATSAPP_ACCESS_TOKEN=

# ===== WhatsApp (AiSensy — deprecated, kept for back-compat; safe to remove) =====
AISENSY_API_KEY=

# ===== Cron auth =====
# Any long random string — required header on /api/sheets/sync etc.
CRON_SECRET=

# ===== App password gate (shared-password auth) =====
# Set both to enable login protection. If either is unset, the app is OPEN
# (fine for local dev; do NOT deploy to Vercel without these set).
ADMIN_PASSWORD=
AUTH_COOKIE_SECRET=

# ===== Opt-out / unsubscribe =====
# HMAC secret for signing unsubscribe-link tokens. Long random string.
OPT_OUT_SECRET=
# Public base URL used in unsubscribe links inside outbound emails.
# Local dev: http://localhost:3000. Prod: your deployed URL.
APP_BASE_URL=http://localhost:3000
